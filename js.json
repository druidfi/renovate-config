{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "packageRules": [
    {
      "matchDatasources": [
        "npm",
        "node-version"
      ],
      "addLabels": [
        "js"
      ]
    },
    {
      "matchDatasources": [
        "npm"
      ],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchDatasources": [
        "npm"
      ],
      "updateTypes": ["major"],
      "enabled": false
    },
    {
      "matchDatasources": [
        "node-version"
      ],
      "updateTypes": ["minor", "patch"],
      "enabled": false
    },
    {
      "matchDatasources": [
        "node-version"
      ],
      "allowedVersions": "/^[0-9]*[02468]\\./"
    }
  ]
}
