{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    ":preserveSemverRanges"
  ],
  "allowPlugins": true,
  "allowScripts": true,
  "separateMinorPatch": false,
  "ignorePresets": [
    "group:symfony"
  ],
  "packageRules": [
    {
      "managers": ["composer"],
      "rangeStrategy": "update-lockfile"
    },
    {
      "updateTypes": ["patch"],
      "matchPackagePrefixes": [
        "doctrine/",
        "sensio/",
        "symfony/",
        "twig/"
      ],
      "groupName": "Symfony packages",
      "labels": [
        "symfony",
        "php"
      ],
      "draftPR": false
    },
    {
      "updateTypes": ["minor", "major"],
      "matchPackagePrefixes": [
        "doctrine/",
        "sensio/",
        "symfony/",
        "twig/"
      ],
      "enabled": false
    },
    {
      "packageNames": [
        "dbrekelmans/bdi",
        "friendsofphp/php-cs-fixer",
        "phpunit/phpunit",
        "rector/rector",
        "symfony/panther",
        "symfony/phpunit-bridge"
      ],
      "groupName": "Symfony Tools",
      "rangeStrategy": "replace",
      "labels": [
        "symfony",
        "tools"
      ]
    }
  ]
}
